#include <stdio.h>
#include <stdlib.h>
#include <locale.h>

//Armazenar os dados de cada item

typedef struct
{
    char nome[50];
    int  quantidade;
    float preco;

} Item;

//Função para calcular o valor total do estoque 

float calcularEstoque(Item *estoque, int qtdItens)
{
    float total = 0.0;

    for (int i = 0; i < qtdItens; i++)
    {
        total += (estoque + i) -> quantidade *
                (estoque + i) -> preco;
    }
    return total;
}

int main()
{
 setlocale(LC_ALL, "Portuguese")
 
 int qtdItens;
 float valorTotal;

